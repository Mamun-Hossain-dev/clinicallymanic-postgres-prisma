model Banner {
  id          String       @id @default(uuid())
  title       String
  description String
  image       String
  type        String
  status      BannerStatus @default(ACTIVE)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

enum BannerStatus {
  ACTIVE
  INACTIVE
}
