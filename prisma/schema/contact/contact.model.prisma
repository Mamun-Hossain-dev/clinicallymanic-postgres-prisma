model Contact {
  id          String  @id @default(uuid())
  name        String
  email       String
  phoneNumber String
  occupation  String
  subject     String
  message     String
  isRead      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead])
  @@index([createdAt(sort: Desc)])
  @@map("contacts")
}
