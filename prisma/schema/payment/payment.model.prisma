model PaymentTransaction {
  id                      String          @id @default(uuid())
  amount                  Decimal         @db.Decimal(10, 2)
  currency                String          @default("usd")
  status                  PaymentStatus   @default(PENDING)
  type                    PaymentType
  provider                PaymentProvider @default(STRIPE)
  stripeCheckoutSessionId String          @unique
  stripePaymentIntentId   String?
  metadata                Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String?
  product   ShopProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  orderId String?    @unique
  order   ShopOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  subscriptionId String?
  subscriptionRefunds SubscriptionRefund[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([type, status])
  @@index([subscriptionId])
  @@index([createdAt(sort: Desc)])
  @@map("payment_transactions")
}

model PaymentWebhookEvent {
  id              String               @id @default(uuid())
  provider        PaymentProvider      @default(STRIPE)
  providerEventId String               @unique
  eventType       String
  status          WebhookProcessStatus @default(RECEIVED)
  payload         Json
  errorMessage    String?
  processedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([provider, status])
  @@index([createdAt(sort: Desc)])
  @@map("payment_webhook_events")
}

enum PaymentProvider {
  STRIPE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentType {
  SHOP
  SUBSCRIPTION
}

enum WebhookProcessStatus {
  RECEIVED
  PROCESSED
  SKIPPED
  FAILED
}
