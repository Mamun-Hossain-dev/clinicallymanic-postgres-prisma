model Content {
  id                String      @id @default(uuid())
  type              ContentType
  title             String
  description       String
  category          String
  thumbnailUrl      String?
  thumbnailPublicId String?

  // ARTICLE only
  body String? @db.Text

  // YOUTUBE only
  videoUrl String?

  // SPOTIFY only
  audioUrl String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([type, category])
  @@index([createdAt(sort: Desc)])
  @@map("contents")
}

enum ContentType {
  ARTICLE
  YOUTUBE
  SPOTIFY
}
